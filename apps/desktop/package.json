  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.8.3"
  }
}
